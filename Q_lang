## 9. GRAMMAR (Formal Specification)

For those who want the exact BNF-style grammar:

```
script       := statement*
statement    := backtest_decl | market_decl | ticker_decl | period_decl
              | use_decl | buy_rule | sell_rule
              | capital_decl | possize_decl | stoploss_decl
              | takeprofit_decl | commission_decl | slippage_decl

backtest_decl  := 'BACKTEST' STRING
market_decl    := 'MARKET'   IDENT
ticker_decl    := 'TICKER'   IDENT
period_decl    := 'PERIOD'   IDENT           # e.g. "1Y", "6M"

use_decl       := 'USE' IDENT ( '(' num_list ')' )?
num_list       := NUMBER ( ',' NUMBER )*

buy_rule       := 'BUY'  'WHEN' condition
sell_rule      := 'SELL' 'WHEN' condition

capital_decl   := 'CAPITAL'       NUMBER
possize_decl   := 'POSITION_SIZE' PERCENT
stoploss_decl  := 'STOP_LOSS'     PERCENT
takeprofit_decl:= 'TAKE_PROFIT'   PERCENT
commission_decl:= 'COMMISSION'    PERCENT
slippage_decl  := 'SLIPPAGE'      PERCENT

condition      := cond_term ( ('AND' | 'OR') cond_term )*
cond_term      := 'NOT'? cond_atom
cond_atom      := '(' condition ')' | comparison | crossover

comparison     := value comp_op value
crossover      := value ('CROSSES_ABOVE' | 'CROSSES_BELOW') value
comp_op        := '>' | '<' | '>=' | '<=' | '==' | '!='

value          := NUMBER
               | IDENT ( '(' num_list ')' )?    # indicator or price field

IDENT          := [A-Za-z_][A-Za-z0-9_]*
NUMBER         := [0-9]+ ('.' [0-9]+)?
PERCENT        := NUMBER '%'
STRING         := '"' [^"]* '"'
COMMENT        := '#' [^\n]*
```

